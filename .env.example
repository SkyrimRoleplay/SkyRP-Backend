# ── HTTP server ───────────────────────────────────────────────────────────────
# Port the Express backend listens on.
PORT=4000

# ── Game server connection ────────────────────────────────────────────────────
# IP / hostname of the game server (for status checks and metrics proxy).
SKYMP_HOST=127.0.0.1

# UDP port of the game server.
SKYMP_PORT=7777

# ── Server metadata ───────────────────────────────────────────────────────────
# These values are returned by GET /api/serverinfo and GET /api/servers.
# They describe the game server to the launcher — keep them in sync with
# the game server's own server-settings.json.
SERVER_NAME=Frostfall Roleplay
SERVER_MAX_PLAYERS=100
SERVER_OFFLINE_MODE=false
SERVER_NPC_ENABLED=false
# Optional short label shown in the launcher (e.g. "Roleplay", "PvP").
# SERVER_GAMEMODE=Roleplay

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# These must match the values in the game server's discordAuth config.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Redirect URI registered in the Discord application (must match exactly).
# DISCORD_REDIRECT_URI=https://your-backend.example.com/auth/callback

# ── Metrics HTTP auth ─────────────────────────────────────────────────────────
# Basic auth credentials for the game server's /metrics endpoint (port 3000).
# Must match the metricsAuth block in the game server's server-settings.json.
# Leave empty if the metrics endpoint has no auth.
METRICS_USER=
METRICS_PASSWORD=

# ── GitHub webhook ────────────────────────────────────────────────────────────
# Must match the "Secret" field in the GitHub repo webhook settings.
GITHUB_WEBHOOK_SECRET=replace-with-a-strong-random-secret

# Branch that triggers a client pull + merge when a push is received.
# CLIENT_BRANCH=refs/heads/main
